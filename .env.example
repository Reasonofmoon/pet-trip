# PetTrip Planner - Environment Variables

# 한국관광공사 반려동물 동반여행 API Key
DATA_GO_KR_KEY=your_api_key_here

# Anthropic Claude API Key (for AI course generation)
ANTHROPIC_API_KEY=your_claude_api_key_here

# Kakao Maps API Key (optional - falls back to Leaflet/OSM)
NEXT_PUBLIC_KAKAO_MAP_KEY=

# Base URL (for production)
NEXT_PUBLIC_BASE_URL=http://localhost:3000
